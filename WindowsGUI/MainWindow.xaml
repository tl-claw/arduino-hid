<Window x:Class="ArduinoHID.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:ArduinoHID.ViewModels"
        xmlns:conv="clr-namespace:ArduinoHID.Converters"
        mc:Ignorable="d"
        Title="Arduino HID Controller" 
        Height="700" Width="900"
        Background="#1e1e1e" 
        Foreground="White"
        FontFamily="Segoe UI"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <conv:BoolToConnectionTextConverter x:Key="BoolToText"/>
        <conv:BoolToConnectionColorConverter x:Key="BoolToColor"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        
        <!-- Button Style -->
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="#3a3a3a"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#4a4a4a"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#2a2a2a"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Key Button Style -->
        <Style x:Key="KeyButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="MinWidth" Value="40"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <!-- GroupBox Override -->
        <Style TargetType="GroupBox">
            <Setter Property="BorderBrush" Value="#444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="5"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title + Connection -->
        <DockPanel Grid.Row="0" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Arduino HID Controller" FontSize="20" FontWeight="Bold"/>
                <Ellipse Width="10" Height="10" Margin="15,0,5,0"
                         Fill="{Binding IsConnected, Converter={StaticResource BoolToColor}}"/>
                <TextBlock Text="{Binding IsConnected, Converter={StaticResource BoolToText}}" 
                           VerticalAlignment="Center" Foreground="#888"/>
            </StackPanel>
            
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <ComboBox ItemsSource="{Binding AvailablePorts}" 
                          SelectedItem="{Binding SelectedPort}"
                          Width="120" Margin="0,0,5,0"
                          VerticalContentAlignment="Center"/>
                <Button Content="↻" Command="{Binding RefreshPortsCommand}" 
                        Style="{StaticResource ActionButton}" Width="35"
                        ToolTip="Refresh ports"/>
                <Button Content="{Binding IsConnected, Converter={StaticResource BoolToText}}"
                        Width="90">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource ActionButton}">
                            <Setter Property="Command" Value="{Binding ConnectCommand}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                    <Setter Property="Command" Value="{Binding DisconnectCommand}"/>
                                    <Setter Property="Background" Value="#c0392b"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </DockPanel>

        <!-- Keyboard Section -->
        <GroupBox Grid.Row="1" Header="Keyboard">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Special Keys Row 1 -->
                <WrapPanel Grid.Row="0" Margin="0,0,0,5">
                    <Button Content="WIN" Command="{Binding SendKeyCommand}" CommandParameter="WIN" Style="{StaticResource KeyButton}"/>
                    <Button Content="R" Command="{Binding SendKeyCommand}" CommandParameter="R" Style="{StaticResource KeyButton}"/>
                    <Button Content="TAB" Command="{Binding SendKeyCommand}" CommandParameter="TAB" Style="{StaticResource KeyButton}"/>
                    <Button Content="ESC" Command="{Binding SendKeyCommand}" CommandParameter="ESCAPE" Style="{StaticResource KeyButton}"/>
                    <Button Content="ENTER" Command="{Binding SendKeyCommand}" CommandParameter="ENTER" Style="{StaticResource KeyButton}" MinWidth="60"/>
                    <Button Content="SPACE" Command="{Binding SendKeyCommand}" CommandParameter="SPACE" Style="{StaticResource KeyButton}" MinWidth="60"/>
                    <Button Content="BS" Command="{Binding SendKeyCommand}" CommandParameter="BACKSPACE" Style="{StaticResource KeyButton}"/>
                </WrapPanel>

                <!-- Arrow Keys -->
                <WrapPanel Grid.Row="1" Margin="0,0,0,5">
                    <Button Content="↑" Command="{Binding SendKeyCommand}" CommandParameter="UP" Style="{StaticResource KeyButton}"/>
                    <Button Content="↓" Command="{Binding SendKeyCommand}" CommandParameter="DOWN" Style="{StaticResource KeyButton}"/>
                    <Button Content="←" Command="{Binding SendKeyCommand}" CommandParameter="LEFT" Style="{StaticResource KeyButton}"/>
                    <Button Content="→" Command="{Binding SendKeyCommand}" CommandParameter="RIGHT" Style="{StaticResource KeyButton}"/>
                    <Button Content="HOME" Command="{Binding SendKeyCommand}" CommandParameter="HOME" Style="{StaticResource KeyButton}"/>
                    <Button Content="END" Command="{Binding SendKeyCommand}" CommandParameter="END" Style="{StaticResource KeyButton}"/>
                    <Button Content="PGUP" Command="{Binding SendKeyCommand}" CommandParameter="PAGEUP" Style="{StaticResource KeyButton}"/>
                    <Button Content="PGDN" Command="{Binding SendKeyCommand}" CommandParameter="PAGEDOWN" Style="{StaticResource KeyButton}"/>
                </WrapPanel>

                <!-- Function Keys -->
                <WrapPanel Grid.Row="2" Margin="0,0,0,5">
                    <Button Content="F1" Command="{Binding SendKeyCommand}" CommandParameter="F1" Style="{StaticResource KeyButton}"/>
                    <Button Content="F2" Command="{Binding SendKeyCommand}" CommandParameter="F2" Style="{StaticResource KeyButton}"/>
                    <Button Content="F3" Command="{Binding SendKeyCommand}" CommandParameter="F3" Style="{StaticResource KeyButton}"/>
                    <Button Content="F4" Command="{Binding SendKeyCommand}" CommandParameter="F4" Style="{StaticResource KeyButton}"/>
                    <Button Content="F5" Command="{Binding SendKeyCommand}" CommandParameter="F5" Style="{StaticResource KeyButton}"/>
                    <Button Content="F6" Command="{Binding SendKeyCommand}" CommandParameter="F6" Style="{StaticResource KeyButton}"/>
                    <Button Content="F7" Command="{Binding SendKeyCommand}" CommandParameter="F7" Style="{StaticResource KeyButton}"/>
                    <Button Content="F8" Command="{Binding SendKeyCommand}" CommandParameter="F8" Style="{StaticResource KeyButton}"/>
                    <Button Content="F9" Command="{Binding SendKeyCommand}" CommandParameter="F9" Style="{StaticResource KeyButton}"/>
                    <Button Content="F10" Command="{Binding SendKeyCommand}" CommandParameter="F10" Style="{StaticResource KeyButton}"/>
                    <Button Content="F11" Command="{Binding SendKeyCommand}" CommandParameter="F11" Style="{StaticResource KeyButton}"/>
                    <Button Content="F12" Command="{Binding SendKeyCommand}" CommandParameter="F12" Style="{StaticResource KeyButton}"/>
                    <Button Content="CAPS" Command="{Binding SendKeyCommand}" CommandParameter="CAPSLOCK" Style="{StaticResource KeyButton}"/>
                    <Button Content="DEL" Command="{Binding SendKeyCommand}" CommandParameter="DELETE" Style="{StaticResource KeyButton}"/>
                </WrapPanel>

                <!-- Symbols -->
                <WrapPanel Grid.Row="3" Margin="0,0,0,5">
                    <Button Content="-" Command="{Binding SendKeyCommand}" CommandParameter="-" Style="{StaticResource KeyButton}"/>
                    <Button Content="+" Command="{Binding SendKeyCommand}" CommandParameter="+" Style="{StaticResource KeyButton}"/>
                </WrapPanel>

                <!-- Modifiers -->
                <StackPanel Grid.Row="4" Orientation="Horizontal">
                    <CheckBox Content="Shift" IsChecked="{Binding ShiftModifier}" Foreground="White" Margin="0,0,15,0"/>
                    <CheckBox Content="Ctrl" IsChecked="{Binding CtrlModifier}" Foreground="White" Margin="0,0,15,0"/>
                    <CheckBox Content="Alt" IsChecked="{Binding AltModifier}" Foreground="White" Margin="0,0,15,0"/>
                    <CheckBox Content="Meta" IsChecked="{Binding MetaModifier}" Foreground="White" Margin="0,0,15,0"/>
                    <Button Content="RELEASE ALL" Command="{Binding ReleaseAllCommand}" Style="{StaticResource KeyButton}" 
                            Background="#8b0000" MinWidth="100"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- Text Input + Mouse Section -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Text Input -->
            <GroupBox Grid.Column="0" Header="Text Input">
                <DockPanel>
                    <Button Content="Send" Command="{Binding SendTextCommand}" 
                            Style="{StaticResource ActionButton}" Width="60"
                            DockPanel.Dock="Right" Margin="5,0,0,0"/>
                    <TextBox Text="{Binding TextInput, UpdateSourceTrigger=PropertyChanged}"
                             Background="#2a2a2a" Foreground="White" 
                             BorderBrush="#444" BorderThickness="1"
                             VerticalContentAlignment="Center"
                             Padding="5,0">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding SendTextCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>
                </DockPanel>
            </GroupBox>

            <!-- Mouse Control -->
            <GroupBox Grid.Column="1" Header="Mouse">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                        <TextBlock Text="X:" Foreground="White" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBox Text="{Binding MouseX, UpdateSourceTrigger=PropertyChanged}" 
                                 Background="#2a2a2a" Foreground="White" 
                                 BorderBrush="#444" BorderThickness="1"
                                 Width="60" VerticalContentAlignment="Center" Padding="5,0"/>
                        <TextBlock Text="Y:" Foreground="White" VerticalAlignment="Center" Margin="10,0,5,0"/>
                        <TextBox Text="{Binding MouseY, UpdateSourceTrigger=PropertyChanged}" 
                                 Background="#2a2a2a" Foreground="White" 
                                 BorderBrush="#444" BorderThickness="1"
                                 Width="60" VerticalContentAlignment="Center" Padding="5,0"/>
                        <Button Content="MOVE" Command="{Binding MouseMoveRelativeCommand}"
                                Style="{StaticResource ActionButton}" Margin="10,0,0,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="LEFT" Command="{Binding ClickCommand}" CommandParameter="left" 
                                Style="{StaticResource KeyButton}"/>
                        <Button Content="RIGHT" Command="{Binding ClickCommand}" CommandParameter="right" 
                                Style="{StaticResource KeyButton}"/>
                        <Button Content="MID" Command="{Binding ClickCommand}" CommandParameter="middle" 
                                Style="{StaticResource KeyButton}"/>
                        <Button Content="↑" Command="{Binding ScrollCommand}" CommandParameter="up" 
                                Style="{StaticResource KeyButton}" ToolTip="Scroll up"/>
                        <Button Content="↓" Command="{Binding ScrollCommand}" CommandParameter="down" 
                                Style="{StaticResource KeyButton}" ToolTip="Scroll down"/>
                    </StackPanel>
                </StackPanel>
            </GroupBox>
        </Grid>

        <!-- Command Log -->
        <GroupBox Grid.Row="3" Header="Command Log">
            <DockPanel>
                <Button Content="Clear" Command="{Binding ClearLogCommand}" 
                        Style="{StaticResource ActionButton}" Width="60"
                        DockPanel.Dock="Bottom" HorizontalAlignment="Left"
                        Margin="0,5,0,0"/>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <TextBlock Text="{Binding CommandLog}" 
                               FontFamily="Consolas" FontSize="12"
                               Background="#0d0d0d" Foreground="#00ff00"
                               Padding="5" TextWrapping="Wrap"/>
                </ScrollViewer>
            </DockPanel>
        </GroupBox>

        <!-- Custom Command + Status -->
        <Grid Grid.Row="4" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Custom Command -->
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <TextBlock Text=">" Foreground="#888" VerticalAlignment="Center" Margin="0,0,5,0" FontFamily="Consolas"/>
                <TextBox Text="{Binding CustomCommand, UpdateSourceTrigger=PropertyChanged}"
                         Background="#2a2a2a" Foreground="White" 
                         BorderBrush="#444" BorderThickness="1"
                         Width="300" VerticalContentAlignment="Center" Padding="5,0">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Enter" Command="{Binding SendCustomCommandCommand}"/>
                    </TextBox.InputBindings>
                </TextBox>
                <Button Content="Execute" Command="{Binding SendCustomCommandCommand}" 
                        Style="{StaticResource ActionButton}" Margin="5,0,0,0"/>
            </StackPanel>

            <!-- Status -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Port: " Foreground="#888"/>
                <TextBlock Text="{Binding SelectedPort}" Foreground="#aaa"/>
                <TextBlock Text=" | Baud: 115200" Foreground="#888" Margin="10,0,0,0"/>
                <CheckBox Content="No Timeout" IsChecked="{Binding NoTimeout}" 
                         Foreground="#aaa" Margin="15,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
